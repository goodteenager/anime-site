PORT=5000

# Для локальной разработки (Docker):
DB_HOST=127.0.0.1
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=anime_db

# Для продакшена (Neon и т.д.) — один URL вместо отдельных полей:
# DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

JWT_SECRET=your-super-secret-jwt-key
YUMMY_APP_TOKEN=your_yummy_token

# CORS — через запятую (для продакшена добавь URL фронтенда):
# CORS_ORIGINS=http://localhost:3000,https://your-site.vercel.app
